# =============================================================================
# Root Environment Configuration
# Purpose: Shared variables for local native development and Azure deployment.
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# Locally, services run natively on localhost. On Azure, connection strings
# and credentials are supplied by the managed services (Azure Database for
# PostgreSQL, Azure Cache for Redis) and injected by the deployment pipeline.
# Do not commit real secrets to this file.
# =============================================================================

# Application
APP_NAME=FraudGuard
DEBUG=true
VERSION=0.1.0
ENVIRONMENT=development

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=fraud_detection
DATABASE_URL=postgresql+asyncpg://fraud_user:change_me_local@localhost:5432/fraud_detection

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=dev-only-do-not-use-in-production-generate-new-key
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Notifications — SMTP email + Twilio SMS (alerts go to registration email/phone)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
NOTIFICATION_FROM_EMAIL=alerts@fraudguard.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
