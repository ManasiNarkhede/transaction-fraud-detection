# =============================================================================
# Git Attributes
# Real-Time Transaction Fraud Detection Guard
# =============================================================================
# Enforce LF line endings for cross-platform consistency
# =============================================================================

# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.env* text eol=lf

# Declare files that will always have CRLF line endings on checkout
# (None — we standardize on LF)

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
