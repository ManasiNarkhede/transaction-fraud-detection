# =============================================================================
# Backend Environment Configuration
# Owned by: Pydantic Settings (backend/app/core/config.py)
# Purpose: FastAPI application configuration
# =============================================================================
# Copy this file to backend/.env and adjust values:
#   cp backend/.env.example backend/.env
# =============================================================================

# Application
APP_NAME=FraudGuard
DEBUG=true
VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=Real-Time Transaction Fraud Detection Guard

# Database
DATABASE_URL=postgresql+asyncpg://fraudguard:fraudguard_dev@localhost:5432/fraudguard
DB_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
# WARNING: This is a DEVELOPMENT-ONLY key. DO NOT use in production.
# Generate a secure key for production: openssl rand -hex 32
JWT_SECRET_KEY=dev-only-do-not-use-in-production-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Python Path
PYTHONPATH=.

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# External APIs (Phase 2+)
# EXTERNAL_API_KEY=your_api_key_here
# EXTERNAL_API_BASE_URL=https://api.example.com

# ML Model Configuration (Phase 3+)
# ML_MODEL_PATH=./models/fraud_detection_v1.pkl
# ML_MODEL_THRESHOLD=0.75
