# =============================================================================
# Frontend Environment Configuration
# Owned by: Vite (vite.config.ts)
# Purpose: React application build-time configuration
# =============================================================================
# Copy this file to frontend/.env and adjust values:
#   cp frontend/.env.example frontend/.env
# =============================================================================
# NOTE: All variables must be prefixed with VITE_ to be exposed to the client.
#
# AZURE STATIC WEB APPS DEPLOYMENT:
#   VITE_API_BASE_URL is consumed at BUILD TIME by the GitHub Actions workflow
#   (.github/workflows/azure-static-web-apps.yml). Vite inlines it into the
#   static bundle — it is NOT a runtime SWA app setting.
#
#   Set it as a GitHub repository VARIABLE (not a secret):
#     GitHub > Settings > Secrets and variables > Variables > New repository variable
#     Name:  VITE_API_BASE_URL
#     Value: https://<your-app-service-name>.azurewebsites.net
#     (no trailing slash; must equal the Azure App Service URL exactly)
#
#   The backend CORS_ORIGINS App Setting must include the SWA URL:
#     https://<your-swa-name>.azurestaticapps.net
# =============================================================================

# API — local dev
VITE_API_BASE_URL=http://localhost:8000

# API — Azure App Service (set VITE_API_BASE_URL as a GitHub repository variable for CI builds)
# VITE_API_BASE_URL=https://<your-app-service-name>.azurewebsites.net

# Application
VITE_APP_NAME=FraudGuard
VITE_APP_VERSION=0.1.0
